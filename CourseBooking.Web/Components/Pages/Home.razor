@page "/"
@inject CourseBooking.Application.Abstractions.IPublicCatalogService CatalogService

<PageTitle>NessiBooking</PageTitle>

<section class="page-section">
    <MudPaper Class="hero-shell" Elevation="0">
        <MudGrid Spacing="4" Class="hero-grid">
            <MudItem xs="12" lg="7">
                <MudStack Spacing="3" Class="hero-main">
                    <MudText Typo="Typo.overline" Class="hero-kicker">NessiBooking</MudText>
                    <MudText Typo="Typo.h3" Class="hero-title">Passenden Kurs auswählen, in Ruhe vergleichen und direkt online anfragen.</MudText>
                    <MudText Typo="Typo.body1" Class="hero-lead">Interne Kurse lassen sich direkt anfragen. Externe Kurse sind klar gekennzeichnet und führen ohne Umwege zum richtigen Anbieter.</MudText>

                    <MudStack Row="true" Spacing="2" Class="hero-actions">
                        <MudButton Href="/register"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.EditNote">
                            Zur Anmeldung
                        </MudButton>
                        <MudButton Href="#kursliste"
                                   Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Search">
                            Kurse ansehen
                        </MudButton>
                    </MudStack>

                    <MudText Typo="Typo.body2" Class="hero-support">
                        Ohne Konto, mit klarer Rückmeldung per E-Mail und sauberer Trennung zwischen interner Anfrage und externer Buchung.
                    </MudText>
                </MudStack>
            </MudItem>

            <MudItem xs="12" lg="5">
                <MudCard Outlined="true" Class="hero-process-card">
                    <MudCardContent>
                        <MudText Typo="Typo.overline" Class="hero-process-kicker">So läuft es ab</MudText>
                        <MudText Typo="Typo.h6" Class="mb-3">In drei klaren Schritten zur Anfrage</MudText>

                        <MudStack Spacing="2">
                            <div class="hero-step">
                                <div class="hero-step-index">1</div>
                                <div class="hero-step-copy">
                                    <MudText Typo="Typo.subtitle2">Kurs eingrenzen</MudText>
                                    <MudText Typo="Typo.body2">Bereich, Unterkategorie, Ort und Turnus so weit auswählen, wie es für Ihre Suche hilfreich ist.</MudText>
                                </div>
                            </div>

                            <MudDivider />

                            <div class="hero-step">
                                <div class="hero-step-index">2</div>
                                <div class="hero-step-copy">
                                    <MudText Typo="Typo.subtitle2">Wunschkurse angeben</MudText>
                                    <MudText Typo="Typo.body2">Bei internen Kursen können mehrere Prioritäten angegeben werden, damit die Zuteilung leichter fällt.</MudText>
                                </div>
                            </div>

                            <MudDivider />

                            <div class="hero-step">
                                <div class="hero-step-index">3</div>
                                <div class="hero-step-copy">
                                    <MudText Typo="Typo.subtitle2">Rückmeldung erhalten</MudText>
                                    <MudText Typo="Typo.body2">Nach dem Absenden prüfen wir die Anfrage und melden uns anschließend per E-Mail bei Ihnen.</MudText>
                                </div>
                            </div>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4 surface-card" Elevation="0">
        <div class="page-header">
            <div>
                <MudText Typo="Typo.h5">Kurse filtern</MudText>
                <MudText Typo="Typo.body2">Wählen Sie nur die Angaben aus, die Ihnen bei der Suche wirklich helfen.</MudText>
            </div>
            <MudButton Variant="Variant.Text" OnClick="ResetFilters" Disabled="_isLoading">Filter zurücksetzen</MudButton>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_loadError</MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Bereich" @bind-Value="_categoryId" @bind-Value:after="OnCategoryChangedAsync" ToStringFunc="FormatCategory">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Bereiche</MudSelectItem>
                    @foreach (var item in _catalog?.Categories ?? Array.Empty<LookupItemDto>())
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Unterkategorie" @bind-Value="_courseTypeId" Disabled="@(!AvailableCourseTypes.Any())" ToStringFunc="FormatCourseType">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Unterkategorien</MudSelectItem>
                    @foreach (var item in AvailableCourseTypes)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Ort / Bad" @bind-Value="_venueId" ToStringFunc="FormatVenue">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Orte</MudSelectItem>
                    @foreach (var item in _catalog?.Venues ?? Array.Empty<LookupItemDto>())
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Turnus" @bind-Value="_cycleId" ToStringFunc="FormatCycle">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Turnusse</MudSelectItem>
                    @foreach (var item in _catalog?.Cycles ?? Array.Empty<LookupItemDto>())
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="DayOfWeek?" Label="Wochentag" @bind-Value="_dayOfWeek">
                    <MudSelectItem T="DayOfWeek?" Value="@((DayOfWeek?)null)">Alle Wochentage</MudSelectItem>
                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                    {
                        <MudSelectItem T="DayOfWeek?" Value="@day">@UiLabels.Day(day)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="CourseRegistrationMode?" Label="Buchungsart" @bind-Value="_registrationMode">
                    <MudSelectItem T="CourseRegistrationMode?" Value="@((CourseRegistrationMode?)null)">Intern und extern</MudSelectItem>
                    <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.Internal">Nur intern</MudSelectItem>
                    <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.External">Nur extern</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="_onlyWithFreeSpots" Color="Color.Primary">Nur aktuell buchbare Kurse</MudSwitch>
            </MudItem>
        </MudGrid>

        <div class="inline-actions mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync" Disabled="_isLoading">Kurse anzeigen</MudButton>
            <MudText Typo="Typo.body2">@((_catalog?.Courses.Count ?? 0)) Kurse gefunden</MudText>
        </div>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
        Interne Kurse führen direkt zum Anfrageformular. Externe Kurse werden klar als extern gekennzeichnet.
    </MudAlert>

    <div id="kursliste">
        @if (_isLoading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_catalog?.Courses.Any() == true)
        {
            <MudGrid>
                @foreach (var course in _catalog.Courses)
                {
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4 mb-4 catalog-card surface-card" Elevation="0">
                            <div class="page-header">
                                <div>
                                    <MudText Typo="Typo.h6">@course.Title</MudText>
                                    <MudText Typo="Typo.body2">@course.Category · @course.CourseType</MudText>
                                </div>
                                <div class="status-stack">
                                    <StatusBadge CourseState="@course.Status" />
                                    <StatusBadge Text="@UiLabels.RegistrationMode(course.RegistrationMode)" />
                                </div>
                            </div>

                            <div class="catalog-meta">
                                <MudText Typo="Typo.body2">@course.Venue</MudText>
                                <MudText Typo="Typo.body2">@course.DayLabel, @course.TimeLabel</MudText>
                                <MudText Typo="Typo.body2">@course.PeriodLabel</MudText>
                                <MudText Typo="Typo.body2">Alter: @course.AgeLabel</MudText>
                                <MudText Typo="Typo.body2">Turnus: @(course.Cycle ?? "flexibel")</MudText>
                            </div>

                            <div class="catalog-chip-row">
                                <MudChip T="string" Color="@GetAvailabilityColor(course)" Variant="Variant.Outlined">@GetAvailabilityLabel(course)</MudChip>
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined">@GetPriceLabel(course)</MudChip>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(course.CustomerNotice))
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">@course.CustomerNotice</MudAlert>
                            }

                            <div class="inline-actions mt-4">
                                <MudButton Variant="Variant.Text" Href="@($"/courses/{course.Id}")">Details</MudButton>
                                @if (course.RegistrationMode == CourseRegistrationMode.Internal)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/register?courseId={course.Id}")">Intern anfragen</MudButton>
                                }
                                else if (!string.IsNullOrWhiteSpace(course.ExternalRegistrationUrl))
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="@course.ExternalRegistrationUrl" Target="_blank">Extern öffnen</MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Outlined" Disabled="true">Externer Link fehlt</MudButton>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Für diese Auswahl wurden aktuell keine Kurse gefunden.</MudAlert>
        }
    </div>
</section>

@code {
    private CatalogPageDto? _catalog;
    private Guid? _categoryId;
    private Guid? _courseTypeId;
    private Guid? _venueId;
    private Guid? _cycleId;
    private DayOfWeek? _dayOfWeek;
    private CourseRegistrationMode? _registrationMode;
    private bool _onlyWithFreeSpots;
    private bool _isLoading;
    private string? _loadError;

    private IReadOnlyList<CategorizedLookupItemDto> AvailableCourseTypes => (_catalog?.CourseTypes ?? Array.Empty<CategorizedLookupItemDto>())
        .Where(x => !_categoryId.HasValue || x.CategoryId == _categoryId.Value)
        .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _catalog = await CatalogService.GetCatalogAsync(new CourseFilterDto(_categoryId, _courseTypeId, _venueId, _cycleId, _dayOfWeek, _registrationMode, _onlyWithFreeSpots));
            if (_courseTypeId.HasValue && AvailableCourseTypes.All(x => x.Id != _courseTypeId.Value))
            {
                _courseTypeId = null;
            }
        }
        catch (Exception ex)
        {
            _loadError = UiFeedback.FromException(ex, "Die Kursliste konnte gerade nicht geladen werden. Bitte versuchen Sie es erneut.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task OnCategoryChangedAsync()
    {
        if (_courseTypeId.HasValue && AvailableCourseTypes.All(x => x.Id != _courseTypeId.Value))
        {
            _courseTypeId = null;
        }

        return Task.CompletedTask;
    }

    private async Task ResetFilters()
    {
        _categoryId = null;
        _courseTypeId = null;
        _venueId = null;
        _cycleId = null;
        _dayOfWeek = null;
        _registrationMode = null;
        _onlyWithFreeSpots = false;
        await LoadAsync();
    }

    private static string GetPriceLabel(CourseListItemDto course) => course.Price > 0 ? $"{course.Price:C}" : "Preis auf Anfrage";

    private static string GetAvailabilityLabel(CourseListItemDto course)
    {
        if (course.RegistrationMode == CourseRegistrationMode.External)
        {
            return "Externe Anmeldung";
        }

        if (course.IsPubliclyBookable)
        {
            return "Direkt anfragbar";
        }

        if (course.AllowWaitlistWhenFull)
        {
            return "Nur Warteliste";
        }

        return "Derzeit nicht buchbar";
    }

    private static Color GetAvailabilityColor(CourseListItemDto course)
    {
        if (course.RegistrationMode == CourseRegistrationMode.External)
        {
            return Color.Secondary;
        }

        if (course.IsPubliclyBookable)
        {
            return Color.Success;
        }

        return course.AllowWaitlistWhenFull ? Color.Warning : Color.Default;
    }

    private string FormatCategory(Guid? id) => FormatLookupLabel(id, _catalog?.Categories);

    private string FormatCourseType(Guid? id) => id.HasValue
        ? (_catalog?.CourseTypes.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty)
        : string.Empty;

    private string FormatVenue(Guid? id) => FormatLookupLabel(id, _catalog?.Venues);

    private string FormatCycle(Guid? id) => FormatLookupLabel(id, _catalog?.Cycles);

    private static string FormatLookupLabel(Guid? id, IEnumerable<LookupItemDto>? items)
        => !id.HasValue ? string.Empty : (items?.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty);
}
