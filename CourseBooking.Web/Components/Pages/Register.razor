@page "/register"
@inject CourseBooking.Application.Abstractions.IPublicCatalogService CatalogService
@inject CourseBooking.Application.Abstractions.IRegistrationService RegistrationService
@inject FluentValidation.IValidator<RegistrationCreateRequest> Validator
@inject NavigationManager NavigationManager

<PageTitle>Anmeldung</PageTitle>

<section class="page-section">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4">Kursanfrage senden</MudText>
            <MudText Typo="Typo.body1">Bitte geben Sie Ihre Kontaktdaten an und wählen Sie Ihre Wunschkurse in Reihenfolge.</MudText>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_globalError))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_globalError</MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudForm @ref="_form">
                    <MudStack Spacing="3">
                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <div>
                                    <MudText Typo="Typo.h6">1. Kontaktdaten</MudText>
                                    <MudText Typo="Typo.body2">Wir brauchen nur die Angaben, die für die Anfrage und Rückmeldung nötig sind.</MudText>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.GuardianFullName"
                                                      Label="Vor- und Nachname eines Elternteils"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte den Namen des Elternteils angeben."
                                                      Error="@HasError(nameof(_model.GuardianFullName))"
                                                      ErrorText="@GetError(nameof(_model.GuardianFullName))" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.ChildFullName"
                                                      Label="Vor- und Nachname des Kindes"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte den Namen des Kindes angeben."
                                                      Error="@HasError(nameof(_model.ChildFullName))"
                                                      ErrorText="@GetError(nameof(_model.ChildFullName))" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudDatePicker Label="Geburtsdatum des Kindes"
                                                       Date="@_birthDate"
                                                       DateChanged="OnBirthDateChanged"
                                                       Required="true"
                                                       RequiredError="Bitte das Geburtsdatum angeben."
                                                       Disabled="@(_isLoading || _isSubmitting)" />
                                        @if (HasError(nameof(_model.ChildBirthDate)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Error">@GetError(nameof(_model.ChildBirthDate))</MudText>
                                        }
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="Guid?"
                                                   Label="Gewünschter Turnus"
                                                   @bind-Value="_model.PreferredCourseCycleId"
                                                   Disabled="@(_isLoading || _isSubmitting)"
                                                   ToStringFunc="FormatCycle">
                                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">Keine Präferenz</MudSelectItem>
                                            @foreach (var cycle in _cycles)
                                            {
                                                <MudSelectItem T="Guid?" Value="@((Guid?)cycle.Id)">@cycle.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_model.AddressLine1"
                                                      Label="Straße und Hausnummer"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte Straße und Hausnummer angeben."
                                                      Error="@HasError(nameof(_model.AddressLine1))"
                                                      ErrorText="@GetError(nameof(_model.AddressLine1))" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="_model.PostalCode"
                                                      Label="PLZ"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte die PLZ angeben."
                                                      Error="@HasError(nameof(_model.PostalCode))"
                                                      ErrorText="@GetError(nameof(_model.PostalCode))" />
                                    </MudItem>
                                    <MudItem xs="12" md="8">
                                        <MudTextField @bind-Value="_model.City"
                                                      Label="Ort"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte den Ort angeben."
                                                      Error="@HasError(nameof(_model.City))"
                                                      ErrorText="@GetError(nameof(_model.City))" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.PhoneNumber"
                                                      Label="Telefonnummer"
                                                      InputType="InputType.Telephone"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte eine Telefonnummer angeben."
                                                      Error="@HasError(nameof(_model.PhoneNumber))"
                                                      ErrorText="@GetError(nameof(_model.PhoneNumber))" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.Email"
                                                      Label="E-Mail-Adresse"
                                                      InputType="InputType.Email"
                                                      Disabled="@(_isLoading || _isSubmitting)"
                                                      Required="true"
                                                      RequiredError="Bitte eine E-Mail-Adresse angeben."
                                                      Error="@HasError(nameof(_model.Email))"
                                                      ErrorText="@GetError(nameof(_model.Email))" />
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <div class="page-header">
                                    <div>
                                        <MudText Typo="Typo.h6">2. Wunschkurse auswählen</MudText>
                                        <MudText Typo="Typo.body2">Wählen Sie zuerst Bereich und Unterkategorie. Danach stehen nur passende Kurse zur Auswahl.</MudText>
                                    </div>
                                    <MudButton Variant="Variant.Outlined"
                                               OnClick="AddPriority"
                                               Disabled="@(!CanAddPriority || _isLoading || _isSubmitting)">
                                        Weitere Priorität
                                    </MudButton>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="Guid?"
                                                   Label="Bereich"
                                                   @bind-Value="_selectedCategoryId"
                                                   @bind-Value:after="OnCategoryChangedAsync"
                                                   Disabled="@(_isLoading || _isSubmitting)"
                                                   ToStringFunc="FormatCategory">
                                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">Bitte wählen</MudSelectItem>
                                            @foreach (var category in _categories)
                                            {
                                                <MudSelectItem T="Guid?" Value="@((Guid?)category.Id)">@category.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="Guid?"
                                                   Label="Unterkategorie"
                                                   @bind-Value="_selectedCourseTypeId"
                                                   @bind-Value:after="OnCourseTypeChangedAsync"
                                                   Disabled="@(!_selectedCategoryId.HasValue || _isLoading || _isSubmitting)"
                                                   ToStringFunc="FormatCourseType">
                                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">Bitte wählen</MudSelectItem>
                                            @foreach (var courseType in AvailableCourseTypes)
                                            {
                                                <MudSelectItem T="Guid?" Value="@((Guid?)courseType.Id)">@courseType.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                </MudGrid>

                                @if (!_selectedCategoryId.HasValue)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">
                                        Bitte wählen Sie zuerst einen Bereich.
                                    </MudAlert>
                                }
                                else if (!_selectedCourseTypeId.HasValue)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">
                                        Bitte wählen Sie anschließend die passende Unterkategorie.
                                    </MudAlert>
                                }
                                else if (FilteredCourseOptions.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                        Für diese Auswahl sind aktuell keine intern anfragbaren Kurse vorhanden.
                                    </MudAlert>
                                }

                                <MudStack Spacing="2">
                                    @for (var i = 0; i < _priorities.Count; i++)
                                    {
                                        var row = _priorities[i];
                                        var rowOptions = GetPriorityCourseOptions(row.Key);

                                        <MudCard Outlined="true" Class="surface-card register-priority-row" @key="row.Key">
                                            <MudCardContent>
                                                <MudGrid Spacing="2">
                                                    <MudItem xs="12" md="2">
                                                        <MudTextField Value="@($"Priorität {row.PriorityOrder}")" ReadOnly="true" Label="Reihenfolge" />
                                                    </MudItem>
                                                    <MudItem xs="12" md="8">
                                                        <MudSelect T="Guid?"
                                                                   Label="Kurs auswählen"
                                                                   Value="@row.CourseOfferingId"
                                                                   ValueChanged="@(value => SetPriorityCourse(row.Key, value))"
                                                                   Disabled="@(!_selectedCourseTypeId.HasValue || _isLoading || _isSubmitting)"
                                                                   ToStringFunc="FormatCourseOption">
                                                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">Bitte wählen</MudSelectItem>
                                                            @foreach (var option in rowOptions)
                                                            {
                                                                <MudSelectItem T="Guid?" Value="@((Guid?)option.Id)" @key="option.Id">@option.Label</MudSelectItem>
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                    <MudItem xs="12" md="2" Class="d-flex align-center">
                                                        <MudButton Variant="Variant.Text"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemovePriority(row.Key))"
                                                                   Disabled="@(_priorities.Count == 1 || _isLoading || _isSubmitting)">
                                                            Entfernen
                                                        </MudButton>
                                                    </MudItem>
                                                </MudGrid>
                                            </MudCardContent>
                                        </MudCard>
                                    }
                                </MudStack>

                                @if (HasError("Priorities"))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">@GetError("Priorities")</MudText>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <div>
                                    <MudText Typo="Typo.h6">3. Abschließen</MudText>
                                    <MudText Typo="Typo.body2">Optional können Sie noch eine Mitteilung ergänzen.</MudText>
                                </div>

                                <MudTextField @bind-Value="_model.Note"
                                              Label="Optionale Mitteilung an uns"
                                              Lines="3"
                                              Disabled="@(_isLoading || _isSubmitting)" />

                                <MudStack Spacing="1" Class="checklist-stack">
                                    <MudCheckBox @bind-Value="_model.TermsAccepted"
                                                 Color="Color.Primary"
                                                 Disabled="@(_isLoading || _isSubmitting)">
                                        Ich akzeptiere die Teilnahmebedingungen.
                                    </MudCheckBox>
                                    @if (HasError(nameof(_model.TermsAccepted)))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error">@GetError(nameof(_model.TermsAccepted))</MudText>
                                    }

                                    <MudCheckBox @bind-Value="_model.PrivacyAccepted"
                                                 Color="Color.Primary"
                                                 Disabled="@(_isLoading || _isSubmitting)">
                                        Ich habe die Datenschutz-Hinweise gelesen.
                                    </MudCheckBox>
                                    @if (HasError(nameof(_model.PrivacyAccepted)))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error">@GetError(nameof(_model.PrivacyAccepted))</MudText>
                                    }
                                </MudStack>

                                <MudStack Row="true" Spacing="2" Class="inline-actions">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="SubmitAsync"
                                               Disabled="@(_isSubmitting || _isLoading)">
                                        Anfrage absenden
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Href="/">Zurück zur Kursliste</MudButton>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                    </MudStack>
                </MudForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.h6">Ihre Übersicht</MudText>
                <MudStack Spacing="2" Class="mt-3">
                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1">@_priorities.Count Prioritäten</MudText>
                            <MudText Typo="Typo.body2">Je mehr passende Wünsche Sie angeben, desto leichter ist die Zuteilung.</MudText>
                        </MudCardContent>
                    </MudCard>
                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1">@(FilteredCourseOptions.Count) passende Kurse</MudText>
                            <MudText Typo="Typo.body2">Die Liste passt sich direkt an Bereich und Unterkategorie an.</MudText>
                        </MudCardContent>
                    </MudCard>
                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1">Rückmeldung per E-Mail</MudText>
                            <MudText Typo="Typo.body2">Nach dem Absenden prüfen wir die Anfrage und melden uns anschließend bei Ihnen.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudStack>

                @if (_preselectedCourse is not null)
                {
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6">Vorab ausgewählt</MudText>
                    <MudCard Outlined="true" Class="surface-card mt-3 selected-course-card">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1">@_preselectedCourse.Label</MudText>
                            <MudText Typo="Typo.body2">Dieser Kurs wurde bereits für die erste Priorität vorgemerkt.</MudText>
                        </MudCardContent>
                    </MudCard>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</section>

@code {
    [SupplyParameterFromQuery(Name = "courseId")]
    public Guid? CourseId { get; set; }

    private readonly RegistrationFormModel _model = new();
    private readonly List<PriorityRow> _priorities = new();
    private Dictionary<string, string> _errors = new(StringComparer.OrdinalIgnoreCase);
    private List<LookupItemDto> _categories = new();
    private List<CategorizedLookupItemDto> _courseTypes = new();
    private List<RegistrationCourseOptionDto> _courseOptions = new();
    private List<LookupItemDto> _cycles = new();
    private LookupItemDto? _preselectedCourse;
    private DateTime? _birthDate;
    private Guid? _selectedCategoryId;
    private Guid? _selectedCourseTypeId;
    private MudForm? _form;
    private string? _globalError;
    private string? _loadError;
    private bool _isSubmitting;
    private bool _isLoading;

    private IReadOnlyList<CategorizedLookupItemDto> AvailableCourseTypes => _courseTypes
        .Where(x => !_selectedCategoryId.HasValue || x.CategoryId == _selectedCategoryId.Value)
        .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<RegistrationCourseOptionDto> FilteredCourseOptions => _courseOptions
        .Where(x => (!_selectedCategoryId.HasValue || x.CategoryId == _selectedCategoryId.Value)
            && (!_selectedCourseTypeId.HasValue || x.CourseTypeId == _selectedCourseTypeId.Value))
        .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private bool CanAddPriority => FilteredCourseOptions.Count > 0 && _priorities.Count < FilteredCourseOptions.Count;

    protected override async Task OnInitializedAsync()
    {
        await LoadOptionsAsync();
    }

    private async Task LoadOptionsAsync()
    {
        _isLoading = true;
        _loadError = null;
        _globalError = null;

        try
        {
            var formOptions = await CatalogService.GetRegistrationFormOptionsAsync();
            _categories = formOptions.Categories.ToList();
            _courseTypes = formOptions.CourseTypes.ToList();
            _courseOptions = formOptions.Courses.ToList();
            _cycles = formOptions.Cycles.ToList();

            if (_priorities.Count == 0)
            {
                AddPriority();
            }

            if (CourseId.HasValue)
            {
                var selectedCourse = _courseOptions.FirstOrDefault(x => x.Id == CourseId.Value);
                if (selectedCourse is not null)
                {
                    _selectedCategoryId = selectedCourse.CategoryId;
                    _selectedCourseTypeId = selectedCourse.CourseTypeId;
                    _priorities[0].CourseOfferingId = selectedCourse.Id;
                    _preselectedCourse = new LookupItemDto(selectedCourse.Id, selectedCourse.Label);
                }
                else
                {
                    _globalError = "Der vorab gewählte Kurs ist nicht mehr verfügbar. Bitte wählen Sie einen anderen Kurs aus.";
                }
            }
        }
        catch (Exception ex)
        {
            _loadError = UiFeedback.FromException(ex, "Das Anfrageformular konnte gerade nicht geladen werden. Bitte versuchen Sie es erneut.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void AddPriority()
    {
        _priorities.Add(new PriorityRow
        {
            Key = Guid.NewGuid(),
            PriorityOrder = _priorities.Count + 1
        });
    }

    private Task OnCategoryChangedAsync()
    {
        if (_selectedCourseTypeId.HasValue && AvailableCourseTypes.All(x => x.Id != _selectedCourseTypeId.Value))
        {
            _selectedCourseTypeId = null;
        }

        _errors.Remove("Priorities");
        PruneInvalidPrioritySelections();
        return Task.CompletedTask;
    }

    private Task OnCourseTypeChangedAsync()
    {
        _errors.Remove("Priorities");
        PruneInvalidPrioritySelections();
        return Task.CompletedTask;
    }

    private void RemovePriority(Guid key)
    {
        var index = _priorities.FindIndex(x => x.Key == key);
        if (index < 0)
        {
            return;
        }

        _priorities.RemoveAt(index);
        _errors.Remove("Priorities");
        NormalizePriorities();
    }

    private void SetPriorityCourse(Guid key, Guid? value)
    {
        var row = _priorities.FirstOrDefault(x => x.Key == key);
        if (row is null)
        {
            return;
        }

        row.CourseOfferingId = value;
        _errors.Remove("Priorities");
    }

    private IReadOnlyList<RegistrationCourseOptionDto> GetPriorityCourseOptions(Guid rowKey)
    {
        var selectedCourseIds = _priorities
            .Where(x => x.Key != rowKey && x.CourseOfferingId.HasValue)
            .Select(x => x.CourseOfferingId!.Value)
            .ToHashSet();

        return FilteredCourseOptions
            .Where(x =>
            {
                var currentValue = _priorities.FirstOrDefault(row => row.Key == rowKey)?.CourseOfferingId;
                return x.Id == currentValue || !selectedCourseIds.Contains(x.Id);
            })
            .ToList();
    }

    private void PruneInvalidPrioritySelections()
    {
        var allowedCourseIds = FilteredCourseOptions.Select(x => x.Id).ToHashSet();
        var seenCourseIds = new HashSet<Guid>();

        foreach (var priority in _priorities)
        {
            if (!priority.CourseOfferingId.HasValue)
            {
                continue;
            }

            if (!allowedCourseIds.Contains(priority.CourseOfferingId.Value) || !seenCourseIds.Add(priority.CourseOfferingId.Value))
            {
                priority.CourseOfferingId = null;
            }
        }
    }

    private void NormalizePriorities()
    {
        for (var i = 0; i < _priorities.Count; i++)
        {
            _priorities[i].PriorityOrder = i + 1;
        }
    }

    private async Task SubmitAsync()
    {
        _globalError = null;
        _errors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (_form is not null)
        {
            await _form.ValidateAsync();
        }

        _isSubmitting = true;

        try
        {
            if (_priorities.Any(x => !x.CourseOfferingId.HasValue))
            {
                _errors["Priorities"] = "Bitte wählen Sie für jede Priorität einen Kurs.";
                return;
            }

            var request = new RegistrationCreateRequest
            {
                GuardianFullName = _model.GuardianFullName,
                ChildFullName = _model.ChildFullName,
                ChildBirthDate = _model.ChildBirthDate,
                AddressLine1 = _model.AddressLine1,
                PostalCode = _model.PostalCode,
                City = _model.City,
                PhoneNumber = _model.PhoneNumber,
                Email = _model.Email,
                PreferredCourseCycleId = _model.PreferredCourseCycleId,
                TermsAccepted = _model.TermsAccepted,
                PrivacyAccepted = _model.PrivacyAccepted,
                Note = _model.Note,
                Priorities = _priorities.Select(x => new RegistrationPriorityInputDto(x.CourseOfferingId!.Value, x.PriorityOrder)).ToList()
            };

            var validationResult = await Validator.ValidateAsync(request);
            if (!validationResult.IsValid)
            {
                _errors = validationResult.Errors
                    .GroupBy(x => x.PropertyName)
                    .ToDictionary(x => x.Key, x => x.First().ErrorMessage, StringComparer.OrdinalIgnoreCase);
                return;
            }

            var result = await RegistrationService.SubmitAsync(request);
            NavigationManager.NavigateTo($"/registration/submitted/{result.ConfirmationNumber}");
        }
        catch (Exception ex)
        {
            _globalError = UiFeedback.FromException(ex, "Die Anfrage konnte gerade nicht abgesendet werden. Bitte prüfen Sie Ihre Angaben und versuchen Sie es erneut.");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void OnBirthDateChanged(DateTime? value)
    {
        _birthDate = value;
        _model.ChildBirthDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
    }

    private bool HasError(string field) => _errors.ContainsKey(field);
    private string GetError(string field) => _errors.TryGetValue(field, out var error) ? error : string.Empty;

    private string FormatCategory(Guid? id) => FormatLookupLabel(id, _categories);

    private string FormatCourseType(Guid? id) => id.HasValue
        ? (_courseTypes.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty)
        : string.Empty;

    private string FormatCycle(Guid? id) => FormatLookupLabel(id, _cycles);

    private string FormatCourseOption(Guid? id) => id.HasValue
        ? (_courseOptions.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty)
        : string.Empty;

    private static string FormatLookupLabel(Guid? id, IEnumerable<LookupItemDto> items)
        => !id.HasValue ? string.Empty : (items.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty);

    private sealed class RegistrationFormModel
    {
        public string GuardianFullName { get; set; } = string.Empty;
        public string ChildFullName { get; set; } = string.Empty;
        public DateOnly? ChildBirthDate { get; set; }
        public string AddressLine1 { get; set; } = string.Empty;
        public string PostalCode { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public Guid? PreferredCourseCycleId { get; set; }
        public bool TermsAccepted { get; set; }
        public bool PrivacyAccepted { get; set; }
        public string? Note { get; set; }
    }

    private sealed class PriorityRow
    {
        public Guid Key { get; set; }
        public int PriorityOrder { get; set; }
        public Guid? CourseOfferingId { get; set; }
    }
}
