@page "/admin/registrations"
@attribute [Authorize(Policy = PolicyNames.AdminOnly)]
@inject CourseBooking.Application.Abstractions.IAdminRegistrationService RegistrationService

<PageTitle>Anmeldungen</PageTitle>

<section class="page-section">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4">Anmeldungen</MudText>
            <MudText Typo="Typo.body1">Eingänge filtern, Prioritäten prüfen und direkt in die Bearbeitung wechseln.</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Href="@BuildExportUrl()">CSV-Export</MudButton>
    </div>

    <AdminNav />

    @if (_page is null)
    {
        <MudProgressCircular Indeterminate="true" Class="mt-6" />
    }
    else
    {
        <div class="stats-grid stats-grid-wide admin-summary-cards">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Alle Anmeldungen</MudText>
                <MudText Typo="Typo.h4">@_page.Summary.Total</MudText>
                <MudText Typo="Typo.body2">@_page.Summary.Open offen</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Bestätigt</MudText>
                <MudText Typo="Typo.h4">@_page.Summary.Confirmed</MudText>
                <MudText Typo="Typo.body2">Fixe Zuweisungen</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Warteliste</MudText>
                <MudText Typo="Typo.h4">@_page.Summary.Waitlisted</MudText>
                <MudText Typo="Typo.body2">Benötigt Nachverfolgung</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Abgelehnt</MudText>
                <MudText Typo="Typo.h4">@_page.Summary.Rejected</MudText>
                <MudText Typo="Typo.body2">Abgeschlossene Fälle</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4 mt-4 mb-4 surface-card" Elevation="0">
            <div class="page-header">
                <div>
                    <MudText Typo="Typo.h6">Liste eingrenzen</MudText>
                    <MudText Typo="Typo.body2">Status, Kurs, Ort und Turnus helfen beim schnellen Vorsortieren.</MudText>
                </div>
                <div class="inline-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Anwenden</MudButton>
                    <MudButton Variant="Variant.Text" OnClick="ResetFilters">Zurücksetzen</MudButton>
                </div>
            </div>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_searchText" Label="Suche" Placeholder="Name, Kind oder E-Mail" Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="RegistrationStatus?" Label="Status" @bind-Value="_status">
                        <MudSelectItem T="RegistrationStatus?" Value="@((RegistrationStatus?)null)">Alle Status</MudSelectItem>
                        @foreach (var status in Enum.GetValues<RegistrationStatus>())
                        {
                            <MudSelectItem T="RegistrationStatus?" Value="@status">@UiLabels.RegistrationState(status)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Kurs" @bind-Value="_courseOfferingId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Kurse</MudSelectItem>
                        @foreach (var item in _page.Courses)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Ort" @bind-Value="_venueId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Orte</MudSelectItem>
                        @foreach (var item in _page.Venues)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Turnus" @bind-Value="_cycleId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Turnusse</MudSelectItem>
                        @foreach (var item in _page.Cycles)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="CourseRegistrationMode?" Label="Buchungsart" @bind-Value="_registrationMode">
                        <MudSelectItem T="CourseRegistrationMode?" Value="@((CourseRegistrationMode?)null)">Intern und extern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.Internal">Nur intern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.External">Nur extern</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 surface-card" Elevation="0">
            <MudTable Items="FilteredRegistrations" Hover="true" Dense="false" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Eingang</MudTh>
                    <MudTh>Familie</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Zugewiesen</MudTh>
                    <MudTh>Prioritäten</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Eingang">@context.SubmittedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Familie">
                        <div>
                            <strong>@context.GuardianName</strong>
                            <MudText Typo="Typo.body2" Class="table-subtext">@context.ChildName · @context.Email</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status"><StatusBadge RegistrationState="@context.Status" /></MudTd>
                    <MudTd DataLabel="Zugewiesen">@(context.AssignedCourse ?? "Noch offen")</MudTd>
                    <MudTd DataLabel="Prioritäten">
                        <MudText Typo="Typo.body2">@context.PrioritySummary</MudText>
                    </MudTd>
                    <MudTd DataLabel="Aktion">
                        <MudButton Variant="Variant.Text" Href="@($"/admin/registrations/{context.Id}")">Öffnen</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</section>

@code {
    private RegistrationListPageDto? _page;
    private RegistrationStatus? _status;
    private Guid? _courseOfferingId;
    private Guid? _venueId;
    private Guid? _cycleId;
    private CourseRegistrationMode? _registrationMode;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private IEnumerable<RegistrationRowDto> FilteredRegistrations => (_page?.Registrations ?? Array.Empty<RegistrationRowDto>())
        .Where(MatchesSearch)
        .ToList();

    private async Task LoadAsync()
    {
        _page = await RegistrationService.GetRegistrationsAsync(new RegistrationAdminFilter(_status, _courseOfferingId, _venueId, _cycleId, _registrationMode));
    }

    private async Task ResetFilters()
    {
        _status = null;
        _courseOfferingId = null;
        _venueId = null;
        _cycleId = null;
        _registrationMode = null;
        _searchText = string.Empty;
        await LoadAsync();
    }

    private bool MatchesSearch(RegistrationRowDto row)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        return $"{row.GuardianName} {row.ChildName} {row.Email} {row.AssignedCourse} {row.PrioritySummary}"
            .Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private string BuildExportUrl()
    {
        var parameters = new List<string>();
        if (_status.HasValue) parameters.Add($"status={_status}");
        if (_courseOfferingId.HasValue) parameters.Add($"courseOfferingId={_courseOfferingId}");
        if (_venueId.HasValue) parameters.Add($"venueId={_venueId}");
        if (_cycleId.HasValue) parameters.Add($"courseCycleId={_cycleId}");
        if (_registrationMode.HasValue) parameters.Add($"registrationMode={_registrationMode}");
        return parameters.Count == 0 ? "/admin/exports/registrations.csv" : $"/admin/exports/registrations.csv?{string.Join("&", parameters)}";
    }
}
