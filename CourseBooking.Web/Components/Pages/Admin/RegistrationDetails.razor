@page "/admin/registrations/{Id:guid}"
@attribute [Authorize(Policy = PolicyNames.AdminOnly)]
@inject CourseBooking.Application.Abstractions.IAdminRegistrationService RegistrationService
@inject CourseBooking.Application.Abstractions.IRegistrationAssignmentService AssignmentService
@inject CourseBooking.Application.Abstractions.IPublicCatalogService CatalogService
@inject ISnackbar Snackbar

<PageTitle>Anmeldung</PageTitle>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="page-section">
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadPageAsync">Erneut laden</MudButton>
    </section>
}
else if (_notFound)
{
    <section class="page-section">
        <MudAlert Severity="Severity.Warning" Class="mb-4">Die gewünschte Anmeldung wurde nicht gefunden.</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/registrations">Zur Liste zurück</MudButton>
    </section>
}
else if (_detail is null)
{
    <MudProgressCircular Indeterminate="true" Class="mt-6" />
}
else
{
    <section class="page-section">
        <div class="page-header">
            <div>
                <MudText Typo="Typo.h4">Anmeldung öffnen</MudText>
                <MudText Typo="Typo.body1">@_detail.GuardianName · @_detail.ChildName · @_detail.SubmittedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
            </div>
            <MudButton Variant="Variant.Text" Href="/admin/registrations">Zur Liste zurück</MudButton>
        </div>

        <AdminNav />

        <div class="page-header mt-4">
            <div class="status-stack">
                <StatusBadge RegistrationState="@_detail.Status" />
                @if (!string.IsNullOrWhiteSpace(_detail.AssignedCourseTitle))
                {
                    <StatusBadge Text="Zugewiesen" />
                }
            </div>
        </div>

        <div class="detail-grid">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.h6">Angaben zur Familie</MudText>
                <div class="account-summary admin-summary">
                    <div class="account-summary-item">
                        <MudText Typo="Typo.overline">Kind</MudText>
                        <MudText Typo="Typo.h6">@_detail.ChildName</MudText>
                        <MudText Typo="Typo.body2">Geburtsdatum: @_detail.ChildBirthDate.ToString("dd.MM.yyyy")</MudText>
                    </div>
                    <div class="account-summary-item">
                        <MudText Typo="Typo.overline">Elternteil / Kontaktperson</MudText>
                        <MudText Typo="Typo.h6">@_detail.GuardianName</MudText>
                        <MudText Typo="Typo.body2">@_detail.Email</MudText>
                    </div>
                    <div class="account-summary-item">
                        <MudText Typo="Typo.overline">Telefon</MudText>
                        <MudText Typo="Typo.h6">@_detail.PhoneNumber</MudText>
                        <MudText Typo="Typo.body2">@_detail.AddressLine1, @_detail.PostalCode @_detail.City</MudText>
                    </div>
                    <div class="account-summary-item">
                        <MudText Typo="Typo.overline">Turnuswunsch</MudText>
                        <MudText Typo="Typo.h6">@(_detail.PreferredCycle ?? "Keine Präferenz")</MudText>
                        <MudText Typo="Typo.body2">Eingang: @_detail.SubmittedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_detail.Note))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                        @_detail.Note
                    </MudAlert>
                }

                <MudText Typo="Typo.h6">Gewünschte Kurse</MudText>
                <div class="dashboard-bars">
                    @foreach (var priority in _detail.Priorities.OrderBy(x => x.PriorityOrder))
                    {
                        <div class="account-quick-link">
                            <span>Priorität @priority.PriorityOrder</span>
                            <small>@priority.CourseLabel</small>
                        </div>
                    }
                </div>
            </MudPaper>

            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudStack Spacing="3">
                    <div>
                        <MudText Typo="Typo.h6">Bearbeitung</MudText>
                        <MudText Typo="Typo.body2">Aktueller Kurs: @(_detail.AssignedCourseTitle ?? "Noch nicht zugewiesen")</MudText>
                    </div>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1">Schnellaktion</MudText>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           Disabled="@_isWorking"
                                           OnClick="AutoAssignAsync">
                                    Automatisch zuweisen
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1">Manuelle Zuweisung</MudText>
                                <MudSelect T="Guid?"
                                           Label="Kurs manuell auswählen"
                                           @bind-Value="_manualCourseId"
                                           Disabled="@_isWorking"
                                           ToStringFunc="FormatCourseOption">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Bitte wählen</MudSelectItem>
                                    @foreach (var item in _courseOptions)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Outlined"
                                           FullWidth="true"
                                           Disabled="@(_isWorking || !_manualCourseId.HasValue)"
                                           OnClick="ManualAssignAsync">
                                    Manuell zuweisen
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1">Status ändern</MudText>
                                <MudSelect T="RegistrationStatus"
                                           Label="Neuer Status"
                                           @bind-Value="_selectedStatus"
                                           Disabled="@_isWorking">
                                    @foreach (var item in Enum.GetValues<RegistrationStatus>())
                                    {
                                        <MudSelectItem T="RegistrationStatus" Value="@item">@UiLabels.RegistrationState(item)</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Outlined"
                                           FullWidth="true"
                                           Disabled="@_isWorking"
                                           OnClick="SaveStatusAsync">
                                    Status speichern
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                    <MudCard Outlined="true" Class="surface-card">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1">Interne Notiz</MudText>
                                <MudTextField @bind-Value="_adminNotes"
                                              Label="Nur für die Verwaltung sichtbar"
                                              Lines="6"
                                              Disabled="@_isWorking" />
                                <MudButton Variant="Variant.Outlined"
                                           FullWidth="true"
                                           Disabled="@_isWorking"
                                           OnClick="SaveNotesAsync">
                                    Notiz speichern
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </MudPaper>
        </div>

        @if (!string.IsNullOrWhiteSpace(_detail.AssignmentProtocol))
        {
            <MudPaper Class="pa-4 mt-4 surface-card" Elevation="0">
                <MudText Typo="Typo.h6">Protokoll</MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-wrap;">@_detail.AssignmentProtocol</MudText>
            </MudPaper>
        }
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private RegistrationDetailDto? _detail;
    private IReadOnlyCollection<LookupItemDto> _courseOptions = Array.Empty<LookupItemDto>();
    private Guid? _manualCourseId;
    private RegistrationStatus _selectedStatus;
    private string _adminNotes = string.Empty;
    private string? _loadError;
    private bool _notFound;
    private bool _isWorking;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadPageAsync();
    }

    private async Task ReloadPageAsync()
    {
        try
        {
            _loadError = null;
            _courseOptions = await CatalogService.GetInternalCourseOptionsAsync();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _detail = null;
            _loadError = UiFeedback.FromException(ex, "Die Anmeldung konnte gerade nicht geladen werden. Bitte versuchen Sie es erneut.");
        }
    }

    private async Task ReloadAsync()
    {
        _detail = await RegistrationService.GetRegistrationAsync(Id);
        _notFound = _detail is null;
        if (_detail is not null)
        {
            _selectedStatus = _detail.Status;
            _adminNotes = _detail.AdminNotes;
            if (_manualCourseId.HasValue && _courseOptions.All(x => x.Id != _manualCourseId.Value))
            {
                _manualCourseId = null;
            }
        }
    }

    private async Task AutoAssignAsync()
    {
        try
        {
            _isWorking = true;
            var result = await AssignmentService.AutoAssignAsync(Id);
            Snackbar.Add(result.Summary, Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiFeedback.FromException(ex, "Die automatische Zuweisung konnte nicht durchgeführt werden. Bitte versuchen Sie es erneut."), Severity.Error);
        }
        finally
        {
            _isWorking = false;
        }
    }

    private async Task ManualAssignAsync()
    {
        if (!_manualCourseId.HasValue)
        {
            return;
        }

        try
        {
            _isWorking = true;
            await AssignmentService.ManualAssignAsync(Id, _manualCourseId.Value, "Manuelle Zuweisung im Adminbereich");
            Snackbar.Add("Teilnehmer wurde zugewiesen.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiFeedback.FromException(ex, "Die manuelle Zuweisung konnte nicht gespeichert werden. Bitte versuchen Sie es erneut."), Severity.Error);
        }
        finally
        {
            _isWorking = false;
        }
    }

    private async Task SaveStatusAsync()
    {
        try
        {
            _isWorking = true;
            await RegistrationService.UpdateStatusAsync(Id, _selectedStatus, null);
            Snackbar.Add("Status gespeichert.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiFeedback.FromException(ex, "Der Status konnte nicht gespeichert werden. Bitte versuchen Sie es erneut."), Severity.Error);
        }
        finally
        {
            _isWorking = false;
        }
    }

    private async Task SaveNotesAsync()
    {
        try
        {
            _isWorking = true;
            await RegistrationService.UpdateAdminNotesAsync(Id, _adminNotes);
            Snackbar.Add("Notiz gespeichert.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiFeedback.FromException(ex, "Die Notiz konnte nicht gespeichert werden. Bitte versuchen Sie es erneut."), Severity.Error);
        }
        finally
        {
            _isWorking = false;
        }
    }

    private string FormatCourseOption(Guid? id)
        => !id.HasValue ? string.Empty : (_courseOptions.FirstOrDefault(x => x.Id == id.Value)?.Label ?? string.Empty);
}
