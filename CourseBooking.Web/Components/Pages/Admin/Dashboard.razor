@page "/admin"
@attribute [Authorize(Policy = PolicyNames.AdminOnly)]
@using System.Globalization
@inject CourseBooking.Application.Abstractions.IAdminDashboardService DashboardService

<PageTitle>Admin Übersicht</PageTitle>

<section class="page-section">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4">Admin-Übersicht</MudText>
            <MudText Typo="Typo.body1">Offene Aufgaben, aktuelle Auslastung und direkte Wege zu den wichtigsten Bereichen.</MudText>
        </div>
    </div>

    <AdminNav />

    @if (_summary is null)
    {
        <MudProgressCircular Indeterminate="true" Class="mt-6" />
    }
    else
    {
        <MudPaper Class="pa-4 mt-4 mb-4 surface-card" Elevation="0">
            <div class="page-header">
                <div>
                    <MudText Typo="Typo.h6">Filter</MudText>
                    <MudText Typo="Typo.body2">Die Anzeige lässt sich auf einen Bereich, eine Unterkategorie oder einen Ort eingrenzen.</MudText>
                </div>
                <div class="inline-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Filter anwenden</MudButton>
                    <MudButton Variant="Variant.Text" OnClick="ResetFilters">Zurücksetzen</MudButton>
                </div>
            </div>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Bereich" Value="@_categoryId" ValueChanged="OnCategoryChanged">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Bereiche</MudSelectItem>
                        @foreach (var item in _summary.Categories)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Unterkategorie" @bind-Value="_courseTypeId" Disabled="@(!AvailableCourseTypes.Any())">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Unterkategorien</MudSelectItem>
                        @foreach (var item in AvailableCourseTypes)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Ort / Bad" @bind-Value="_venueId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Orte</MudSelectItem>
                        @foreach (var item in _summary.Venues)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Turnus" @bind-Value="_cycleId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Turnusse</MudSelectItem>
                        @foreach (var item in _summary.Cycles)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="CourseRegistrationMode?" Label="Buchungsart" @bind-Value="_registrationMode">
                        <MudSelectItem T="CourseRegistrationMode?" Value="@((CourseRegistrationMode?)null)">Intern und extern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.Internal">Nur intern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.External">Nur extern</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="RegistrationStatus?" Label="Anmeldestatus" @bind-Value="_registrationStatus">
                        <MudSelectItem T="RegistrationStatus?" Value="@((RegistrationStatus?)null)">Alle Status</MudSelectItem>
                        @foreach (var status in Enum.GetValues<RegistrationStatus>())
                        {
                            <MudSelectItem T="RegistrationStatus?" Value="@status">@UiLabels.RegistrationState(status)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <div class="stats-grid stats-grid-wide admin-summary-cards">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Offene Anmeldungen</MudText>
                <MudText Typo="Typo.h4">@_summary.OpenRegistrations</MudText>
                <MudText Typo="Typo.body2">Eingegangen oder vorgemerkt</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Bestätigt</MudText>
                <MudText Typo="Typo.h4">@_summary.ConfirmedRegistrations</MudText>
                <MudText Typo="Typo.body2">Bereits fix zugewiesen</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Warteliste</MudText>
                <MudText Typo="Typo.h4">@_summary.WaitlistEntries</MudText>
                <MudText Typo="Typo.body2">Benötigt Nachverfolgung</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Intern buchbar</MudText>
                <MudText Typo="Typo.h4">@_summary.BookableInternalCourses</MudText>
                <MudText Typo="Typo.body2">@_summary.InternalCourses interne Kurse insgesamt</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Wenig Restplätze</MudText>
                <MudText Typo="Typo.h4">@_summary.CoursesWithLowAvailability</MudText>
                <MudText Typo="Typo.body2">Früh prüfen und steuern</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Ausgebuchte Kurse</MudText>
                <MudText Typo="Typo.h4">@(_summary.SoldOutCourses + _summary.ExternalSoldOutCourses)</MudText>
                <MudText Typo="Typo.body2">Intern und extern zusammen</MudText>
            </MudPaper>
        </div>

        <div class="dashboard-grid dashboard-grid-lists">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <div class="page-header">
                    <div>
                        <MudText Typo="Typo.h6">Schnell handeln</MudText>
                        <MudText Typo="Typo.body2">Die Standardaufgaben sollen ohne Umwege erreichbar sein.</MudText>
                    </div>
                </div>

                <div class="admin-action-grid">
                    <a class="admin-quick-link" href="/admin/registrations">
                        <span>Anmeldungen prüfen</span>
                        <small>@_summary.OpenRegistrations offene Vorgänge</small>
                    </a>
                    <a class="admin-quick-link" href="/admin/courses">
                        <span>Kurse pflegen</span>
                        <small>@_summary.BookableInternalCourses interne Kurse aktuell buchbar</small>
                    </a>
                    <a class="admin-quick-link" href="/admin/courses/new">
                        <span>Neuen Kurs anlegen</span>
                        <small>Bewusst getrennte Eingabeseite für neue Angebote</small>
                    </a>
                    <a class="admin-quick-link" href="/admin/catalog">
                        <span>Stammdaten ordnen</span>
                        <small>Bereiche, Unterkategorien, Orte, Turnusse und Vorlagen</small>
                    </a>
                    <a class="admin-quick-link" href="/admin/templates">
                        <span>Mailtexte prüfen</span>
                        <small>Vorlagen für Zusagen, Warteliste und Ablehnungen</small>
                    </a>
                </div>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6">Statusverteilung</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">So verteilen sich die aktuell gefilterten Anmeldungen.</MudText>
                <div class="dashboard-bars">
                    @foreach (var row in _summary.RegistrationStatusDistribution)
                    {
                        <div class="dashboard-bar-row">
                            <div class="dashboard-bar-head">
                                <span>@row.Label</span>
                                <strong>@row.Value</strong>
                            </div>
                            <div class="dashboard-bar-track">
                                <div class="dashboard-bar-fill dashboard-tone-primary" style="@BuildBarStyle(row)"></div>
                            </div>
                        </div>
                    }
                </div>
            </MudPaper>

            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.h6">Bereiche im Blick</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">Die aktuell wichtigsten Angebotsbereiche im gewählten Ausschnitt.</MudText>
                <div class="dashboard-bars">
                    @foreach (var row in _summary.CategoryDistribution)
                    {
                        <div class="dashboard-bar-row">
                            <div class="dashboard-bar-head">
                                <span>@row.Label</span>
                                <strong>@row.Value</strong>
                            </div>
                            <div class="dashboard-bar-track">
                                <div class="dashboard-bar-fill dashboard-tone-accent" style="@BuildBarStyle(row)"></div>
                            </div>
                        </div>
                    }
                </div>
            </MudPaper>
        </div>

        <div class="dashboard-grid dashboard-grid-lists">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <div class="page-header">
                    <div>
                        <MudText Typo="Typo.h6">Kurse mit Handlungsbedarf</MudText>
                        <MudText Typo="Typo.body2">Knappe Plätze, Warteliste oder viele offene Anfragen.</MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Href="/admin/courses">Zur Kursverwaltung</MudButton>
                </div>

                <MudTable Items="_summary.CoursesNeedingAttention" Hover="true" Dense="false" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Kurs</MudTh>
                        <MudTh>Ort</MudTh>
                        <MudTh>Plätze</MudTh>
                        <MudTh>Offen</MudTh>
                        <MudTh>Aktion</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Kurs">
                            <div>
                                <strong>@context.Title</strong>
                                <div class="table-subline">
                                    @if (context.IsSoldOut)
                                    {
                                        <StatusBadge Text="Ausgebucht" />
                                    }
                                    else if (context.IsLowAvailability)
                                    {
                                        <StatusBadge Text="Wenig Plätze" />
                                    }
                                    @if (context.WaitlistCount > 0)
                                    {
                                        <StatusBadge Text="@($"{context.WaitlistCount} Warteliste")" />
                                    }
                                </div>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Ort">@context.Venue</MudTd>
                        <MudTd DataLabel="Plätze">@context.SeatsRemaining / @context.Capacity</MudTd>
                        <MudTd DataLabel="Offen">@context.OpenRegistrations</MudTd>
                        <MudTd DataLabel="Aktion">
                            <MudButton Variant="Variant.Text" Href="@($"/admin/courses/{context.Id}/edit")">Bearbeiten</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>

            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <div class="page-header">
                    <div>
                        <MudText Typo="Typo.h6">Zuletzt geänderte Kurse</MudText>
                        <MudText Typo="Typo.body2">Direkte Rückkehr zu den zuletzt bearbeiteten Angeboten.</MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Href="/admin/courses">Alle Kurse</MudButton>
                </div>

                <MudTable Items="_summary.RecentCourses" Hover="true" Dense="false" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Kurs</MudTh>
                        <MudTh>Bereich</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Geändert</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Kurs">
                            <div>
                                <strong>@context.Title</strong>
                                <MudText Typo="Typo.body2" Class="table-subtext">@context.CourseType</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Bereich">@context.Category</MudTd>
                        <MudTd DataLabel="Status"><StatusBadge CourseState="@context.Status" /></MudTd>
                        <MudTd DataLabel="Geändert">@context.ChangedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudTd>
                        <MudTd DataLabel="Aktion">
                            <MudButton Variant="Variant.Text" Href="@($"/admin/courses/{context.Id}/edit")">Öffnen</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>

            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <div class="page-header">
                    <div>
                        <MudText Typo="Typo.h6">Neueste Anmeldungen</MudText>
                        <MudText Typo="Typo.body2">Direkter Einstieg in die laufende Bearbeitung.</MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Href="/admin/registrations">Alle Anmeldungen</MudButton>
                </div>

                <MudTable Items="_summary.RecentRegistrations" Hover="true" Dense="false" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Eingang</MudTh>
                        <MudTh>Familie</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Eingang">@context.SubmittedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudTd>
                        <MudTd DataLabel="Familie">
                            <div>
                                <strong>@context.GuardianName</strong>
                                <MudText Typo="Typo.body2" Class="table-subtext">@context.ChildName</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Status"><StatusBadge RegistrationState="@context.Status" /></MudTd>
                        <MudTd DataLabel="Aktion">
                            <MudButton Variant="Variant.Text" Href="@($"/admin/registrations/{context.Id}")">Öffnen</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </div>
    }
</section>

@code {
    private DashboardSummaryDto? _summary;
    private Guid? _categoryId;
    private Guid? _courseTypeId;
    private Guid? _venueId;
    private Guid? _cycleId;
    private CourseRegistrationMode? _registrationMode;
    private RegistrationStatus? _registrationStatus;

    private IReadOnlyList<CategorizedLookupItemDto> AvailableCourseTypes => (_summary?.CourseTypes ?? Array.Empty<CategorizedLookupItemDto>())
        .Where(x => !_categoryId.HasValue || x.CategoryId == _categoryId.Value)
        .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _summary = await DashboardService.GetSummaryAsync(
            new AdminDashboardFilter(_categoryId, _courseTypeId, _venueId, _cycleId, _registrationMode, _registrationStatus));
    }

    private async Task OnCategoryChanged(Guid? value)
    {
        _categoryId = value;
        if (_courseTypeId.HasValue && AvailableCourseTypes.All(x => x.Id != _courseTypeId.Value))
        {
            _courseTypeId = null;
        }

        await Task.CompletedTask;
    }

    private async Task ResetFilters()
    {
        _categoryId = null;
        _courseTypeId = null;
        _venueId = null;
        _cycleId = null;
        _registrationMode = null;
        _registrationStatus = null;
        await LoadAsync();
    }

    private static string BuildBarStyle(DashboardBreakdownRowDto row)
    {
        var percentage = row.Total <= 0 ? 0 : Math.Clamp((row.Value * 100d) / row.Total, 0, 100);
        return $"width:{percentage.ToString("F1", CultureInfo.InvariantCulture)}%";
    }
}
