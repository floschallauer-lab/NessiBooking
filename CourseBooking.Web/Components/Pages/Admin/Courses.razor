@page "/admin/courses"
@attribute [Authorize(Policy = PolicyNames.AdminOnly)]
@inject CourseBooking.Application.Abstractions.IAdminCourseService CourseService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Kursverwaltung</PageTitle>

<section class="page-section">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4">Kursverwaltung</MudText>
            <MudText Typo="Typo.body1">Bestehende Kurse suchen, filtern und mit wenigen Klicks bearbeiten.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/courses/new">Neuen Kurs anlegen</MudButton>
    </div>

    <AdminNav />

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadAsync">Erneut laden</MudButton>
    }
    else if (_data is null)
    {
        <MudProgressCircular Indeterminate="true" Class="mt-6" />
    }
    else
    {
        <div class="stats-grid stats-grid-wide admin-summary-cards">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Alle Kurse</MudText>
                <MudText Typo="Typo.h4">@_data.Summary.TotalCourses</MudText>
                <MudText Typo="Typo.body2">@_data.Summary.PublishedCourses veröffentlicht</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Entwürfe</MudText>
                <MudText Typo="Typo.h4">@_data.Summary.DraftCourses</MudText>
                <MudText Typo="Typo.body2">Noch nicht im Kundenbereich sichtbar</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Intern buchbar</MudText>
                <MudText Typo="Typo.h4">@_data.Summary.InternalCourses</MudText>
                <MudText Typo="Typo.body2">@_data.Summary.ExternalCourses externe Kurse</MudText>
            </MudPaper>
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.overline">Handlungsbedarf</MudText>
                <MudText Typo="Typo.h4">@_data.Summary.CoursesWithLowAvailability</MudText>
                <MudText Typo="Typo.body2">@_data.Summary.SoldOutCourses ausgebucht</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4 mt-4 mb-4 surface-card" Elevation="0">
            <div class="page-header">
                <div>
                    <MudText Typo="Typo.h6">Liste eingrenzen</MudText>
                    <MudText Typo="Typo.body2">Suchen Sie nach Titel, Bereich, Unterkategorie, Ort, Kursleitung oder Status.</MudText>
                </div>
                <div class="inline-actions">
                    <MudButton Variant="Variant.Text" OnClick="ResetFilters">Filter zurücksetzen</MudButton>
                    <MudText Typo="Typo.body2">@FilteredCourses.Count() Kurse sichtbar</MudText>
                </div>
            </div>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_searchText" Label="Suche" Placeholder="Titel, Ort oder Kursleitung" Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid?" Label="Bereich" Value="@_categoryFilterId" ValueChanged="OnFilterCategoryChanged">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Alle Bereiche</MudSelectItem>
                        @foreach (var item in _data.Categories)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Unterkategorie" @bind-Value="_courseTypeFilter">
                        <MudSelectItem T="string" Value="@AnyValue">Alle Unterkategorien</MudSelectItem>
                        @foreach (var item in AvailableFilterCourseTypes)
                        {
                            <MudSelectItem T="string" Value="@item.Label">@item.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Ort / Bad" @bind-Value="_venueFilter">
                        <MudSelectItem T="string" Value="@AnyValue">Alle Orte</MudSelectItem>
                        @foreach (var item in GetDistinctValues(_data.Courses.Select(x => x.Venue)))
                        {
                            <MudSelectItem T="string" Value="@item">@item</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Turnus" @bind-Value="_cycleFilter">
                        <MudSelectItem T="string" Value="@AnyValue">Alle Turnusse</MudSelectItem>
                        @foreach (var item in GetDistinctValues(_data.Courses.Select(x => x.Cycle ?? "Kein Turnus")))
                        {
                            <MudSelectItem T="string" Value="@item">@item</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="CourseRegistrationMode?" Label="Buchungsart" @bind-Value="_registrationModeFilter">
                        <MudSelectItem T="CourseRegistrationMode?" Value="@((CourseRegistrationMode?)null)">Intern und extern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.Internal">Nur intern</MudSelectItem>
                        <MudSelectItem T="CourseRegistrationMode?" Value="@CourseRegistrationMode.External">Nur extern</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="CourseOfferingStatus?" Label="Status" @bind-Value="_statusFilter">
                        <MudSelectItem T="CourseOfferingStatus?" Value="@((CourseOfferingStatus?)null)">Alle Status</MudSelectItem>
                        @foreach (var status in Enum.GetValues<CourseOfferingStatus>())
                        {
                            <MudSelectItem T="CourseOfferingStatus?" Value="@status">@UiLabels.CourseStatus(status)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-center">
                    <MudSwitch T="bool" @bind-Value="_onlyBookable" Color="Color.Primary">Nur intern buchbare Kurse</MudSwitch>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-center">
                    <MudSwitch T="bool" @bind-Value="_includeArchived" Color="Color.Default">Archivierte mitanzeigen</MudSwitch>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 surface-card" Elevation="0">
            <div class="page-header">
                <div>
                    <MudText Typo="Typo.h6">Kursliste</MudText>
                    <MudText Typo="Typo.body2">Die wichtigsten Aktionen stehen direkt in der Zeile.</MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Href="/admin/courses/new">Neueingabe öffnen</MudButton>
            </div>

            <MudTable Items="FilteredCourses"
                      Class="admin-list-table"
                      Hover="true"
                      Dense="false"
                      Breakpoint="Breakpoint.Sm"
                      HorizontalScrollbar="true">
                <HeaderContent>
                    <MudTh>Kurs</MudTh>
                    <MudTh>Termin</MudTh>
                    <MudTh>Ort</MudTh>
                    <MudTh>Kursleitung</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Plätze</MudTh>
                    <MudTh>Aktionen</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Kurs">
                        <div>
                            <strong>@context.Title</strong>
                            <div class="table-subline">
                                <StatusBadge Text="@context.Category" />
                                <StatusBadge Text="@context.CourseType" />
                                <StatusBadge Text="@UiLabels.RegistrationMode(context.RegistrationMode)" />
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Termin">
                        <div>@context.DayLabel</div>
                        <MudText Typo="Typo.body2" Class="table-subtext">@context.PeriodLabel</MudText>
                    </MudTd>
                    <MudTd DataLabel="Ort">@context.Venue</MudTd>
                    <MudTd DataLabel="Kursleitung">@context.InstructorName</MudTd>
                    <MudTd DataLabel="Status"><StatusBadge CourseState="@context.Status" /></MudTd>
                    <MudTd DataLabel="Plätze">
                        @(context.RegistrationMode == CourseRegistrationMode.External ? "Extern" : $"{context.SeatsRemaining} / {context.Capacity}")
                    </MudTd>
                    <MudTd DataLabel="Aktionen">
                        <div class="table-actions">
                            <MudButton Variant="Variant.Text" Href="@($"/admin/courses/{context.Id}/edit")">Bearbeiten</MudButton>
                            <MudButton Variant="Variant.Text" OnClick="@(() => DuplicateCourse(context.Id))">Duplizieren</MudButton>
                            <MudButton Variant="Variant.Text" Href="@($"/admin/courses/{context.Id}/print")">Druck</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => ConfirmArchiveAsync(context.Id, context.Title))">Archivieren</MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</section>

@code {
    private const string AnyValue = "__all";

    private CourseManagementDataDto? _data;
    private string _searchText = string.Empty;
    private Guid? _categoryFilterId;
    private string _courseTypeFilter = AnyValue;
    private string _venueFilter = AnyValue;
    private string _cycleFilter = AnyValue;
    private CourseRegistrationMode? _registrationModeFilter;
    private CourseOfferingStatus? _statusFilter;
    private bool _onlyBookable;
    private bool _includeArchived;
    private string? _loadError;

    private IReadOnlyList<CategorizedLookupItemDto> AvailableFilterCourseTypes => (_data?.CourseTypes ?? Array.Empty<CategorizedLookupItemDto>())
        .Where(x => !_categoryFilterId.HasValue || x.CategoryId == _categoryFilterId.Value)
        .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IEnumerable<CourseManagementRowDto> FilteredCourses => (_data?.Courses ?? Array.Empty<CourseManagementRowDto>())
        .Where(MatchesCourseFilters)
        .ToList();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        try
        {
            _loadError = null;
            _data = await CourseService.GetManagementDataAsync();
            EnsureValidFilterCourseTypeSelection();
        }
        catch (Exception ex)
        {
            _data = null;
            _loadError = UiFeedback.FromException(ex, "Die Kursverwaltung konnte gerade nicht geladen werden. Bitte versuchen Sie es erneut.");
        }
    }

    private void ResetFilters()
    {
        _searchText = string.Empty;
        _categoryFilterId = null;
        _courseTypeFilter = AnyValue;
        _venueFilter = AnyValue;
        _cycleFilter = AnyValue;
        _registrationModeFilter = null;
        _statusFilter = null;
        _onlyBookable = false;
        _includeArchived = false;
    }

    private Task OnFilterCategoryChanged(Guid? value)
    {
        _categoryFilterId = value;
        EnsureValidFilterCourseTypeSelection();
        return Task.CompletedTask;
    }

    private void DuplicateCourse(Guid id)
    {
        NavigationManager.NavigateTo($"/admin/courses/new?copyFrom={id}");
    }

    private async Task ConfirmArchiveAsync(Guid id, string title)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = "Kurs archivieren",
            [nameof(ConfirmDialog.Message)] = $"Soll der Kurs '{title}' wirklich archiviert werden? Archivierte Kurse sind nicht mehr regulär sichtbar.",
            [nameof(ConfirmDialog.ConfirmText)] = "Archivieren",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(string.Empty, parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        try
        {
            await CourseService.ArchiveAsync(id);
            Snackbar.Add("Kurs archiviert.", Severity.Info);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiFeedback.FromException(ex, "Der Kurs konnte nicht archiviert werden. Bitte versuchen Sie es erneut."), Severity.Error);
        }
    }

    private bool MatchesCourseFilters(CourseManagementRowDto course)
    {
        if (!_includeArchived && course.Archived)
        {
            return false;
        }

        if (_statusFilter.HasValue && course.Status != _statusFilter.Value)
        {
            return false;
        }

        if (_registrationModeFilter.HasValue && course.RegistrationMode != _registrationModeFilter.Value)
        {
            return false;
        }

        if (_onlyBookable && !IsBookableInternalCourse(course))
        {
            return false;
        }

        if (_categoryFilterId.HasValue)
        {
            var selectedCategory = _data?.Categories.FirstOrDefault(x => x.Id == _categoryFilterId.Value)?.Label;
            if (!string.Equals(course.Category, selectedCategory, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        if (_courseTypeFilter != AnyValue && !string.Equals(course.CourseType, _courseTypeFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (_venueFilter != AnyValue && !string.Equals(course.Venue, _venueFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var cycleLabel = course.Cycle ?? "Kein Turnus";
        if (_cycleFilter != AnyValue && !string.Equals(cycleLabel, _cycleFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        return $"{course.Title} {course.Venue} {course.CourseType} {course.Category} {course.InstructorName}"
            .Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private void EnsureValidFilterCourseTypeSelection()
    {
        if (_courseTypeFilter == AnyValue)
        {
            return;
        }

        if (AvailableFilterCourseTypes.Any(x => string.Equals(x.Label, _courseTypeFilter, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _courseTypeFilter = AnyValue;
    }

    private static bool IsBookableInternalCourse(CourseManagementRowDto course)
    {
        return course.RegistrationMode == CourseRegistrationMode.Internal
            && course.Status == CourseOfferingStatus.Published
            && course.SeatsRemaining > 0;
    }

    private static IReadOnlyCollection<string> GetDistinctValues(IEnumerable<string> values)
    {
        return values
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }
}
