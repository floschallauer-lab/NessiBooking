    private async Task RunCatalogActionAsync(Func<Task<Guid>> action, string successMessage, Action resetAction)
    {
        try
        {
            await action();
            Snackbar.Add(successMessage, Severity.Success);
            await ReloadAsync();
            resetAction();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmAndRunAsync(string title, string message, Func<Task> action, string successMessage, Action resetAction)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = title,
            [nameof(ConfirmDialog.Message)] = message,
            [nameof(ConfirmDialog.ConfirmText)] = "Löschen",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(string.Empty, parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        try
        {
            await action();
            Snackbar.Add(successMessage, Severity.Info);
            await ReloadAsync();
            resetAction();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static string BuildAgeRangeText(AgeRuleManagementRowDto row)
    {
        var unitLabel = BuildAgeUnitLabel(row.Unit);
        return row switch
        {
            { MinimumValue: not null, MaximumValue: not null } => $"{row.MinimumValue} bis {row.MaximumValue} {unitLabel}",
            { MinimumValue: not null } => $"Ab {row.MinimumValue} {unitLabel}",
            { MaximumValue: not null } => $"Bis {row.MaximumValue} {unitLabel}",
            _ => "Freie Regel"
        };
    }

    private static string BuildAgeUnitLabel(string unit)
        => unit.Equals("Months", StringComparison.OrdinalIgnoreCase) ? "Monate" : "Jahre";

    private static int ResolveTabIndex(string? tab)
    {
        return (tab ?? string.Empty).ToLowerInvariant() switch
        {
            "categories" => 0,
            "coursetypes" => 1,
            "venues" => 2,
            "cycles" => 3,
            "agerules" => 4,
            "instructors" => 5,
            _ => 0
        };
    }

    private static int NextSortOrder(IEnumerable<int>? values)
    {
        return values is null || !values.Any() ? 1 : values.Max() + 1;
    }
