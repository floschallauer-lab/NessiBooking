@page "/courses/{Id:guid}"
@inject CourseBooking.Application.Abstractions.IPublicCatalogService CatalogService

<PageTitle>Kursdetails</PageTitle>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="page-section">
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Zur Kursliste</MudButton>
    </section>
}
else if (_course is null)
{
    <section class="page-section">
        <MudAlert Severity="Severity.Warning">Der Kurs wurde nicht gefunden.</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Zur Kursliste</MudButton>
    </section>
}
else
{
    <section class="page-section">
        <div class="page-header">
            <div>
                <MudText Typo="Typo.h4">@_course.Title</MudText>
                <MudText Typo="Typo.body1">@_course.Category · @_course.CourseType · @_course.Venue</MudText>
            </div>
            <div class="status-stack">
                <StatusBadge CourseState="@_course.Status" />
                <StatusBadge Text="@UiLabels.RegistrationMode(_course.RegistrationMode)" />
            </div>
        </div>

        <MudGrid Spacing="3">
            <MudItem xs="12" lg="7">
                <MudPaper Class="pa-4 surface-card" Elevation="0">
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.h6">Kursbeschreibung</MudText>
                            <MudText Typo="Typo.body1">@(!string.IsNullOrWhiteSpace(_course.Description) ? _course.Description : "Für diesen Kurs ist noch keine Beschreibung hinterlegt.")</MudText>
                        </div>

                        <MudDivider />

                        <div>
                            <MudText Typo="Typo.h6">Wichtige Daten</MudText>
                            <MudStack Spacing="1" Class="mt-3">
                                <MudText Typo="Typo.body2">Ort: @GetVenueAddress(_course)</MudText>
                                <MudText Typo="Typo.body2">Tag: @_course.DayLabel</MudText>
                                <MudText Typo="Typo.body2">Uhrzeit: @_course.TimeLabel</MudText>
                                <MudText Typo="Typo.body2">Zeitraum: @_course.PeriodLabel</MudText>
                                <MudText Typo="Typo.body2">Turnus: @(_course.Cycle ?? "flexibel")</MudText>
                                @if (!string.IsNullOrWhiteSpace(_course.InstructorName))
                                {
                                    <MudText Typo="Typo.body2">Kursleitung: @_course.InstructorName</MudText>
                                }
                                <MudText Typo="Typo.body2">Alter: @_course.AgeLabel</MudText>
                                <MudText Typo="Typo.body2">Preis: @GetPriceLabel(_course)</MudText>
                            </MudStack>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="5">
                <MudPaper Class="pa-4 surface-card" Elevation="0">
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.h6">Anmeldung</MudText>
                            <MudText Typo="Typo.body2">@GetAvailabilityLabel(_course)</MudText>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_course.CustomerNotice))
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">@_course.CustomerNotice</MudAlert>
                        }

                        <MudStack Row="true" Spacing="1" Class="catalog-chip-row">
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined">@GetPriceLabel(_course)</MudChip>
                            @if (_course.RegistrationMode == CourseRegistrationMode.Internal)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined">@($"{Math.Max(_course.SeatsRemaining, 0)} freie Plätze")</MudChip>
                            }
                        </MudStack>

                        <MudStack Row="true" Spacing="2" Class="inline-actions">
                            @if (_course.IsPubliclyBookable)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/register?courseId={_course.Id}")">Intern anfragen</MudButton>
                            }
                            else if (_course.RegistrationMode == CourseRegistrationMode.External && !string.IsNullOrWhiteSpace(_course.ExternalRegistrationUrl))
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="@_course.ExternalRegistrationUrl" Target="_blank">Externe Anmeldung</MudButton>
                            }
                            else if (_course.RegistrationMode == CourseRegistrationMode.External)
                            {
                                <MudButton Variant="Variant.Outlined" Disabled="true">Externer Link fehlt</MudButton>
                            }
                            <MudButton Variant="Variant.Text" Href="/">Zur Kursliste</MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private CourseDetailDto? _course;
    private string? _loadError;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _loadError = null;
            _course = await CatalogService.GetCourseAsync(Id);
        }
        catch (Exception ex)
        {
            _course = null;
            _loadError = UiFeedback.FromException(ex, "Die Kursdetails konnten gerade nicht geladen werden. Bitte versuchen Sie es erneut.");
        }
    }

    private static string GetPriceLabel(CourseDetailDto course) => course.Price > 0 ? $"{course.Price:C}" : "Preis auf Anfrage";

    private static string GetAvailabilityLabel(CourseDetailDto course)
    {
        if (course.RegistrationMode == CourseRegistrationMode.External)
        {
            return "Die Anmeldung läuft über den externen Anbieter.";
        }

        if (course.IsPubliclyBookable)
        {
            return "Dieser Kurs kann direkt über unser Formular angefragt werden.";
        }

        return course.AllowWaitlistWhenFull
            ? "Aktuell ist nur eine Wartelisten-Anfrage möglich."
            : "Dieser Kurs ist derzeit nicht intern anfragbar.";
    }

    private static string GetVenueAddress(CourseDetailDto course)
        => string.IsNullOrWhiteSpace(course.VenueAddress) ? course.Venue : course.VenueAddress;
}
