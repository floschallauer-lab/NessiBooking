@page "/courses/{Id:guid}"
@inject CourseBooking.Application.Abstractions.IPublicCatalogService CatalogService

<PageTitle>Kursdetails</PageTitle>

@if (_course is null)
{
    <MudAlert Severity="Severity.Warning">Der Kurs wurde nicht gefunden.</MudAlert>
}
else
{
    <section class="page-section">
        <div class="page-header">
            <div>
                <MudText Typo="Typo.h4">@_course.Title</MudText>
                <MudText Typo="Typo.body1">@_course.Category · @_course.CourseType · @_course.Venue</MudText>
            </div>
            <div class="status-stack">
                <StatusBadge CourseState="@_course.Status" />
                <StatusBadge Text="@(_course.RegistrationMode == CourseRegistrationMode.External ? "Extern" : "Intern")" />
            </div>
        </div>

        <div class="detail-grid">
            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.body1">@_course.Description</MudText>
                <MudDivider Class="my-3" />
                <div class="catalog-meta">
                    <MudText Typo="Typo.body2">Ort: @_course.VenueAddress</MudText>
                    <MudText Typo="Typo.body2">Tag: @_course.DayLabel</MudText>
                    <MudText Typo="Typo.body2">Uhrzeit: @_course.TimeLabel</MudText>
                    <MudText Typo="Typo.body2">Zeitraum: @_course.PeriodLabel</MudText>
                    <MudText Typo="Typo.body2">Turnus: @(_course.Cycle ?? "flexibel")</MudText>
                    <MudText Typo="Typo.body2">Kursleitung: @_course.InstructorName</MudText>
                    <MudText Typo="Typo.body2">Alter: @_course.AgeLabel</MudText>
                    <MudText Typo="Typo.body2">Preis: @GetPriceLabel(_course)</MudText>
                </div>
            </MudPaper>

            <MudPaper Class="pa-4 surface-card" Elevation="0">
                <MudText Typo="Typo.h6">Buchungsstatus</MudText>
                <MudText Typo="Typo.body2">@GetAvailabilityLabel(_course)</MudText>
                @if (!string.IsNullOrWhiteSpace(_course.CustomerNotice))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">@_course.CustomerNotice</MudAlert>
                }
                <div class="inline-actions" style="margin-top:1rem;">
                    @if (_course.IsPubliclyBookable)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/register?courseId={_course.Id}")">Zur Anmeldung</MudButton>
                    }
                    else if (_course.RegistrationMode == CourseRegistrationMode.External)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="@_course.ExternalRegistrationUrl" Target="_blank">Externe Anmeldung</MudButton>
                    }
                    <MudButton Variant="Variant.Text" Href="/">Zur Übersicht</MudButton>
                </div>
            </MudPaper>
        </div>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private CourseDetailDto? _course;

    protected override async Task OnParametersSetAsync()
    {
        _course = await CatalogService.GetCourseAsync(Id);
    }

    private static string GetPriceLabel(CourseDetailDto course) => course.Price > 0 ? $"{course.Price:C}" : "Preis auf Anfrage";

    private static string GetAvailabilityLabel(CourseDetailDto course)
    {
        if (course.RegistrationMode == CourseRegistrationMode.External)
        {
            return "Die Anmeldung läuft extern über den angegebenen Anbieter.";
        }

        if (course.IsPubliclyBookable)
        {
            return "Der Kurs ist aktuell intern buchbar.";
        }

        return course.AllowWaitlistWhenFull
            ? "Aktuell nur mehr Warteliste oder manuelle Prüfung."
            : "Der Kurs ist derzeit nicht intern buchbar.";
    }
}
