@page "/Account/Register"

<PageTitle>Registrierung deaktiviert</PageTitle>

<MudPaper Class="pa-6" Elevation="0" Style="max-width:640px;margin:2rem auto;">
    <MudText Typo="Typo.h5">Öffentliche Account-Registrierung ist deaktiviert.</MudText>
    <MudText Typo="Typo.body1" Class="mt-2">Der Login ist ausschließlich für Administratoren vorgesehen.</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/Account/Login" Class="mt-4">Zum Login</MudButton>
</MudPaper>
