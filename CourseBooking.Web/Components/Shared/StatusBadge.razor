<MudChip T="string" Color="@ResolveColor()" Variant="Variant.Filled" Size="Size.Small">
    @ResolveLabel()
</MudChip>

@code {
    [Parameter] public CourseOfferingStatus? CourseState { get; set; }
    [Parameter] public RegistrationStatus? RegistrationState { get; set; }
    [Parameter] public string? Text { get; set; }

    private string ResolveLabel()
    {
        if (!string.IsNullOrWhiteSpace(Text))
        {
            return Text;
        }

        if (CourseState.HasValue)
        {
            return UiLabels.CourseStatus(CourseState.Value);
        }

        return RegistrationState.HasValue
            ? UiLabels.RegistrationState(RegistrationState.Value)
            : "Status";
    }

    private Color ResolveColor()
    {
        if (CourseState.HasValue)
        {
            return CourseState.Value switch
            {
                CourseOfferingStatus.Published => Color.Success,
                CourseOfferingStatus.SoldOut => Color.Warning,
                CourseOfferingStatus.Draft => Color.Info,
                CourseOfferingStatus.Archived => Color.Default,
                _ => Color.Default
            };
        }

        return RegistrationState switch
        {
            RegistrationStatus.Received => Color.Info,
            RegistrationStatus.Reserved => Color.Secondary,
            RegistrationStatus.Confirmed => Color.Success,
            RegistrationStatus.Waitlisted => Color.Warning,
            RegistrationStatus.Rejected => Color.Error,
            _ => Color.Default
        };
    }
}
